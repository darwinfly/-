# 產品展示網站環境變數設定範例
# 請複製此檔案並重新命名為 .env，然後修改下方設定值

# ==========================================================================
# 1. 基礎設定
# ==========================================================================
# 管理者後台登入初始密碼 (第一次啟動資料庫時使用)
ADMIN_PASSWORD=admin1234

# Flask Session 密鑰 (隨機字串)
FLASK_SECRET_KEY=some_random_secret_key_for_session_verification

# 網站品牌與標題設定
SITE_NAME=Antigravity Showcase
SITE_TITLE=無重力科技，引領未來硬體
SITE_SUBTITLE=探索突破物理極限的前沿智慧硬體，感受極致創新的無重力世界。

# ==========================================================================
# 2. 雙模儲存與資料庫切換 (本地 / GCP 雲端模式)
# ==========================================================================
# 資料庫模式: 'sqlite' (本地 SQLite) 或 'firestore' (Google Cloud Firestore)
DB_MODE=sqlite

# 檔案儲存模式: 'local' (本地 static/uploads/) 或 'gcs' (Google Cloud Storage)
STORAGE_MODE=local

# ==========================================================================
# 3. Google Cloud Platform (GCP) 設定 (僅當啟用 firestore 或 gcs 模式時需要)
# ==========================================================================
# Google Cloud Storage Bucket 名稱
GCS_BUCKET_NAME=my-product-pdf-bucket

# Google Cloud 應用程式認證檔案路徑 (若在本地模擬測試 GCP 服務)
# GOOGLE_APPLICATION_CREDENTIALS=c:/path/to/your-gcp-service-account-key.json

# ==========================================================================
# 4. Google Picker API & OAuth 2.0 設定 (雲端硬碟匯入功能)
# ==========================================================================
# Google 雲端硬碟 API 金鑰 (API Key)
GOOGLE_API_KEY=AIzaSyYourApiKeyHere...

# Google OAuth 2.0 用戶端 ID (Client ID)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

